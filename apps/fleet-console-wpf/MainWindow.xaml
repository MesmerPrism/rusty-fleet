<Window x:Class="RustyFleet.FleetConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Rusty Fleet"
        Width="1500"
        Height="900"
        MinWidth="1000"
        MinHeight="640"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="InspectorHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,14,0,5" />
        </Style>
        <Style x:Key="InspectorLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="176" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="390" MinWidth="340" MaxWidth="620" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="14"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                AutomationProperties.Name="Primary navigation">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Rusty Fleet"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="4,4,4,18" />
                    <Button Content="Fleet"
                            IsDefault="True"
                            HorizontalContentAlignment="Left"
                            AutomationProperties.Name="Fleet, current page" />
                    <Button Content="Attention · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                    <Button Content="Operations · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                    <Button Content="Media · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                    <Button Content="Audit · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                    <Button Content="Enrollment · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                    <Button Content="Settings · planned"
                            IsEnabled="False"
                            HorizontalContentAlignment="Left" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Text="M1 local monitoring&#x0a;No ADB required"
                           Opacity="0.75"
                           Margin="4" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="16,12,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding SummaryText}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               AutomationProperties.Name="{Binding SummaryText}" />
                    <TextBlock Text="{Binding AsOfText}" Opacity="0.75" />
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock Text="Local Hub"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="EndpointBox"
                             Width="260"
                             Text="{Binding HubAddress, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Local Fleet Hub address"
                             AutomationProperties.HelpText="Only an absolute loopback HTTP address is accepted." />
                    <Button Content="Connect"
                            Command="{Binding ConnectCommand}"
                            AutomationProperties.Name="Connect to local Fleet Hub" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            AutomationProperties.Name="Refresh current fleet scope" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Search"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Search devices"
                         AutomationProperties.HelpText="Matches device display name or stable device identifier." />
                <Button Grid.Column="2"
                        Content="Apply search"
                        Command="{Binding ApplySearchCommand}" />
                <Button Grid.Column="3"
                        Content="Clear"
                        Command="{Binding ClearSearchCommand}" />
            </Grid>

            <Border Grid.Row="2"
                    Padding="8,5"
                    Margin="0,0,0,8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Select all visible"
                                Command="{Binding SelectAllVisibleCommand}" />
                        <Button Content="Clear selection"
                                Command="{Binding ClearBatchSelectionCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding BatchSelectionText}"
                               VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.Name="{Binding BatchSelectionText}" />
                </DockPanel>
            </Border>

            <DataGrid x:Name="FleetGrid"
                      Grid.Row="3"
                      ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="40"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      IsReadOnly="True"
                      FrozenColumnCount="3"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      AutomationProperties.Name="Fleet devices"
                      AutomationProperties.HelpText="Use arrow keys to move, Enter to inspect, and Space to toggle batch selection."
                      SelectionChanged="OnFleetSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Select" Width="72">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsBatchSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          AutomationProperties.Name="{Binding BatchSelectionName}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Attention"
                                        Width="100"
                                        Binding="{Binding AttentionSummary}" />
                    <DataGridTextColumn Header="Device"
                                        Width="220"
                                        Binding="{Binding DeviceSummary}" />
                    <DataGridTextColumn Header="Age"
                                        Width="88"
                                        Binding="{Binding FreshnessText}" />
                    <DataGridTextColumn Header="Route"
                                        Width="112"
                                        Binding="{Binding RouteText}" />
                    <DataGridTextColumn Header="Power"
                                        Width="112"
                                        Binding="{Binding PowerText}" />
                    <DataGridTextColumn Header="App / Kiosk"
                                        Width="220"
                                        Binding="{Binding AppKioskText}" />
                    <DataGridTextColumn Header="Control"
                                        Width="190"
                                        Binding="{Binding ControlText}" />
                    <DataGridTextColumn Header="Privileged"
                                        Width="150"
                                        Binding="{Binding PrivilegedText}" />
                    <DataGridTextColumn Header="Streams"
                                        Width="110"
                                        Binding="{Binding StreamsText}" />
                    <DataGridTextColumn Header="Work"
                                        Width="100"
                                        Binding="{Binding WorkText}" />
                    <DataGridTextColumn Header="Tags / cohort"
                                        Width="160"
                                        Binding="{Binding TagsText}" />
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name"
                                Value="{Binding AccessibleName}" />
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <DockPanel Grid.Row="4" Margin="0,8,0,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ScopeText}"
                           Opacity="0.75" />
                <TextBlock Text="{Binding StatusMessage}"
                           AutomationProperties.Name="{Binding StatusMessage}"
                           AutomationProperties.LiveSetting="Polite" />
            </DockPanel>
        </Grid>

        <Border x:Name="InspectorPane"
                Grid.Column="2"
                Padding="18,12"
                BorderThickness="1,0,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                Focusable="True"
                AutomationProperties.Name="Selected device inspector"
                AutomationProperties.HelpText="Current selected-device observations, capabilities, conditions, work, and streams.">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{Binding Inspector.Title, FallbackValue=No device selected}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Inspector.Identity}"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Inspector.Freshness}"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Attention"
                               Style="{StaticResource InspectorHeading}" />
                    <TextBlock Text="{Binding Inspector.Attention, FallbackValue=Select a device to inspect its independent status families.}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Observed"
                               Style="{StaticResource InspectorHeading}" />
                    <ItemsControl ItemsSource="{Binding Inspector.Facts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Style="{StaticResource InspectorLabel}" />
                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Detail}"
                                               TextWrapping="Wrap"
                                               Opacity="0.72" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Capabilities"
                               Style="{StaticResource InspectorHeading}" />
                    <ItemsControl ItemsSource="{Binding Inspector.Capabilities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Style="{StaticResource InspectorLabel}" />
                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Detail}"
                                               TextWrapping="Wrap"
                                               Opacity="0.72" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Status conditions"
                               Style="{StaticResource InspectorHeading}" />
                    <ItemsControl ItemsSource="{Binding Inspector.Conditions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Style="{StaticResource InspectorLabel}" />
                                    <TextBlock Text="{Binding Value}" />
                                    <TextBlock Text="{Binding Detail}"
                                               TextWrapping="Wrap"
                                               Opacity="0.72" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Current work"
                               Style="{StaticResource InspectorHeading}" />
                    <TextBlock Text="{Binding Inspector.Work, FallbackValue=No device selected}" />

                    <TextBlock Text="Streams"
                               Style="{StaticResource InspectorHeading}" />
                    <TextBlock Text="{Binding Inspector.Streams, FallbackValue=No device selected}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
