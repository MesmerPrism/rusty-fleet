{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesmerprism.com/rusty-fleet/schemas/rusty.fleet.operation_ledger.v1.schema.json",
  "title": "Rusty Fleet operation ledger v1",
  "type": "object",
  "required": [
    "schema",
    "operation_id",
    "action_id",
    "created_at_ms",
    "target_snapshot",
    "lifecycle",
    "cleanup_required",
    "targets"
  ],
  "properties": {
    "schema": {
      "const": "rusty.fleet.operation_ledger.v1"
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_ms": {
      "type": "integer"
    },
    "target_snapshot": {
      "type": "object"
    },
    "lifecycle": {
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "dispatched",
        "running",
        "applied",
        "failed",
        "expired",
        "cancellation_requested",
        "cancelled",
        "cleanup_pending",
        "cleaned"
      ]
    },
    "cleanup_required": {
      "type": "boolean"
    },
    "targets": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
