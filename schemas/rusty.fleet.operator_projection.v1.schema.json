{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mesmerprism.com/rusty-fleet/schemas/rusty.fleet.operator_projection.v1.schema.json",
  "title": "Rusty Fleet operator projection envelope v1",
  "description": "Shared envelope for summary, row, inspector, detail, query-result, and saved-view projections. Domain structs impose the detailed invariants.",
  "oneOf": [
    {
      "$ref": "#/$defs/summary"
    },
    {
      "$ref": "#/$defs/row"
    },
    {
      "$ref": "#/$defs/inspector"
    },
    {
      "$ref": "#/$defs/detail"
    },
    {
      "$ref": "#/$defs/query_result"
    },
    {
      "$ref": "#/$defs/saved_view"
    },
    {
      "$ref": "#/$defs/saved_view_collection"
    },
    {
      "$ref": "#/$defs/saved_view_mutation_request"
    },
    {
      "$ref": "#/$defs/saved_view_mutation_receipt"
    }
  ],
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "schema",
        "as_of_ms",
        "total",
        "fresh",
        "stale",
        "offline",
        "attention",
        "active_work"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.summary.v1"
        }
      }
    },
    "row": {
      "type": "object",
      "required": [
        "schema",
        "identity",
        "source_epoch",
        "accepted_revision",
        "accepted_at_ms",
        "age_ms",
        "freshness"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.device_row.v1"
        },
        "agent": {
          "oneOf": [
            {
              "$ref": "rusty.fleet.device_observation.v1.schema.json#/$defs/application"
            },
            {
              "type": "null"
            }
          ]
        },
        "power": {
          "oneOf": [
            {
              "$ref": "rusty.fleet.device_observation.v1.schema.json#/$defs/power"
            },
            {
              "type": "null"
            }
          ]
        },
        "application": {
          "oneOf": [
            {
              "$ref": "rusty.fleet.device_observation.v1.schema.json#/$defs/application"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "inspector": {
      "type": "object",
      "required": [
        "schema",
        "row",
        "attention",
        "streams",
        "active_operations"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.device_inspector.v1"
        }
      }
    },
    "detail": {
      "type": "object",
      "required": [
        "schema",
        "inspector",
        "condition_history",
        "operation_history"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.device_detail.v1"
        }
      }
    },
    "query_result": {
      "type": "object",
      "required": [
        "schema",
        "query",
        "result_revision",
        "as_of_ms",
        "total_count",
        "window_offset",
        "window_count",
        "rows"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.query_result.v1"
        }
      }
    },
    "saved_view": {
      "type": "object",
      "required": [
        "schema",
        "view_id",
        "name",
        "query",
        "columns",
        "density",
        "restoration",
        "schema_version"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.saved_view.v1"
        },
        "view_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "query": {
          "$ref": "rusty.fleet.query.v1.schema.json"
        },
        "columns": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "density": {
          "enum": [
            "compact",
            "standard",
            "comfortable"
          ]
        },
        "grouping": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "restoration": {
          "$ref": "#/$defs/navigation_restoration"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "navigation_restoration": {
      "type": "object",
      "required": [
        "selected_device_id",
        "inspector_tab",
        "scroll_anchor_device_id",
        "focused_region",
        "collapsed_groups"
      ],
      "properties": {
        "selected_device_id": {
          "$ref": "#/$defs/optional_bounded_text"
        },
        "inspector_tab": {
          "$ref": "#/$defs/optional_bounded_text"
        },
        "scroll_anchor_device_id": {
          "$ref": "#/$defs/optional_bounded_text"
        },
        "focused_region": {
          "$ref": "#/$defs/optional_bounded_text"
        },
        "collapsed_groups": {
          "type": "array",
          "maxItems": 512,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      },
      "additionalProperties": false
    },
    "saved_view_collection": {
      "type": "object",
      "required": [
        "schema",
        "revision",
        "views"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.saved_view_collection.v1"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "views": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/saved_view"
          }
        }
      },
      "additionalProperties": false
    },
    "saved_view_mutation_request": {
      "type": "object",
      "required": [
        "schema",
        "expected_revision",
        "view"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.saved_view_mutation_request.v1"
        },
        "expected_revision": {
          "type": "integer",
          "minimum": 1
        },
        "view": {
          "$ref": "#/$defs/saved_view"
        }
      },
      "additionalProperties": false
    },
    "saved_view_mutation_receipt": {
      "type": "object",
      "required": [
        "schema",
        "view_id",
        "previous_revision",
        "current_revision",
        "changed",
        "deleted",
        "view"
      ],
      "properties": {
        "schema": {
          "const": "rusty.fleet.saved_view_mutation_receipt.v1"
        },
        "view_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?)*$"
        },
        "previous_revision": {
          "type": "integer",
          "minimum": 1
        },
        "current_revision": {
          "type": "integer",
          "minimum": 1
        },
        "changed": {
          "type": "boolean"
        },
        "deleted": {
          "type": "boolean"
        },
        "view": {
          "oneOf": [
            {
              "$ref": "#/$defs/saved_view"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "deleted": {
                "const": true
              }
            },
            "required": [
              "deleted"
            ]
          },
          "then": {
            "properties": {
              "changed": {
                "const": true
              },
              "view": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "deleted": {
                "const": false
              }
            },
            "required": [
              "deleted"
            ]
          },
          "then": {
            "properties": {
              "view": {
                "$ref": "#/$defs/saved_view"
              }
            }
          }
        }
      ]
    },
    "optional_bounded_text": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
